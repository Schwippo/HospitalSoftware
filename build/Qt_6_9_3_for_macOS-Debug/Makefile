	$(QINSTALL) HospitalSoftware.app $(INSTALL_ROOT)/opt/HospitalSoftware/bin/HospitalSoftware.app

uninstall_target: FORCE
	-$(DEL_FILE) -r $(INSTALL_ROOT)/opt/HospitalSoftware/bin/HospitalSoftware.app
	-$(DEL_DIR) $(INSTALL_ROOT)/opt/HospitalSoftware/bin/ 


install: install_target  FORCE

uninstall: uninstall_target  FORCE

FORCE:

.SUFFIXES:

