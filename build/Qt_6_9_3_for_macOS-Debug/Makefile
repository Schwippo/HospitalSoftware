HospitalSoftware.app/Contents/PkgInfo: 
	@test -d HospitalSoftware.app/Contents || mkdir -p HospitalSoftware.app/Contents
	@$(DEL_FILE) HospitalSoftware.app/Contents/PkgInfo
	@echo "APPL????" > HospitalSoftware.app/Contents/PkgInfo
HospitalSoftware.app/Contents/Info.plist: 
	@test -d HospitalSoftware.app/Contents || mkdir -p HospitalSoftware.app/Contents
	@$(DEL_FILE) HospitalSoftware.app/Contents/Info.plist
	@set -o pipefail && plutil -convert xml1 -o - /Users/lena/Qt/6.9.3/macos/mkspecs/macx-clang/Info.plist.app | sed -e "s,@SHORT_VERSION@,1.0,g" -e "s,\$${QMAKE_SHORT_VERSION},1.0,g" -e "s,@FULL_VERSION@,1.0.0,g" -e "s,\$${QMAKE_FULL_VERSION},1.0.0,g" -e "s,@TYPEINFO@,????,g" -e "s,\$${QMAKE_PKGINFO_TYPEINFO},????,g" -e "s,@BUNDLEIDENTIFIER@,lena.HospitalSoftware,g" -e "s,\$${PRODUCT_BUNDLE_IDENTIFIER},lena.HospitalSoftware,g" -e "s,\$${MACOSX_DEPLOYMENT_TARGET},12,g" -e "s,\$${IPHONEOS_DEPLOYMENT_TARGET},,g" -e "s,\$${TVOS_DEPLOYMENT_TARGET},,g" -e "s,\$${WATCHOS_DEPLOYMENT_TARGET},,g" -e "s,\$${IOS_LAUNCH_SCREEN},LaunchScreen,g" -e "s,@ICON@,,g" -e "s,\$${ASSETCATALOG_COMPILER_APPICON_NAME},,g" -e "s,@EXECUTABLE@,HospitalSoftware,g" -e "s,@LIBRARY@,HospitalSoftware,g" -e "s,\$${EXECUTABLE_NAME},HospitalSoftware,g" -e "s,@TYPEINFO@,????,g" -e "s,\$${QMAKE_PKGINFO_TYPEINFO},????,g" >HospitalSoftware.app/Contents/Info.plist

all: Makefile \
		HospitalSoftware.app/Contents/PkgInfo \
